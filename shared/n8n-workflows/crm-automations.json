        "parameters": {
          "operation": "executeQuery",
          "query": "SELECT (SELECT COUNT(*) FROM social.accounts WHERE created_at >= date_trunc('month', now() - interval '1 month') AND created_at < date_trunc('month', now())) AS new_customers, (SELECT COUNT(*) FROM social.subscriptions WHERE status = 'cancelled' AND updated_at >= date_trunc('month', now() - interval '1 month') AND updated_at < date_trunc('month', now())) AS churned, (SELECT COALESCE(SUM(CASE WHEN a.plan_id = 'starter' THEN 499 WHEN a.plan_id = 'pro' THEN 999 WHEN a.plan_id = 'business' THEN 2499 WHEN a.plan_id = 'agency' THEN 4999 ELSE 0 END), 0) FROM social.accounts a JOIN social.subscriptions s ON s.account_id = a.id WHERE s.status = 'active') AS mrr, (SELECT COUNT(*) FROM social.accounts a JOIN social.subscriptions s ON s.account_id = a.id WHERE s.status = 'active') AS active_customers, (SELECT COUNT(*) FROM social.accounts) AS total_accounts, (SELECT COUNT(*) FROM social.posts WHERE created_at >= date_trunc('month', now() - interval '1 month') AND created_at < date_trunc('month', now())) AS posts_last_month",
          "options": {}
        }
      },
      {
