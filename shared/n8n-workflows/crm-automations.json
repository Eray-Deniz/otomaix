        "name": "Build Monthly Report",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          650,
          300
        ],
        "parameters": {
          "jsCode": "const d = $json;\nconst mrr = parseInt(d.mrr) || 0;\nconst arpu = d.active_customers > 0 ? Math.round(mrr / parseInt(d.active_customers)) : 0;\nconst churnRate = d.active_customers > 0 ? ((parseInt(d.churned) / parseInt(d.active_customers)) * 100).toFixed(1) : '0';\n\nconst lastMonth = new Date();\nlastMonth.setMonth(lastMonth.getMonth() - 1);\nconst monthName = lastMonth.toLocaleDateString('tr-TR', { year: 'numeric', month: 'long' });\n\nconst text = `📊 <b>${monthName} Aylık Raporu</b>\\n\\n` +\n  `👥 Aktif Müşteri: ${d.active_customers}\\n` +\n  `🆕 Yeni Müşteri: ${d.new_customers}\\n` +\n  `📉 Churn: ${d.churned} (${churnRate}%)\\n\\n` +\n  `💰 MRR: ₺${mrr.toLocaleString('tr-TR')}\\n` +\n  `📈 ARPU: ₺${arpu.toLocaleString('tr-TR')}\\n\\n` +\n  `📝 Üretilen İçerik: ${d.posts_last_month}\\n` +\n  `🏷️ Toplam Kayıt: ${d.total_accounts}\\n\\n` +\n  `🔗 <a href=\"https://crm.otomaix.com/raporlar\">Detaylı Rapor</a>`;\n\nreturn [{ json: { text } }];"
