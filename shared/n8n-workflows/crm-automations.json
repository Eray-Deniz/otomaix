  {
    "name": "CRM-4: Churn Riski Taraması (Günlük)",
    "active": true,
    "nodes": [
      {
        "id": "f4a2b3c4-0004-0004-0004-000000000001",
        "name": "Schedule Trigger",
        "type": "n8n-nodes-base.scheduleTrigger",
        "typeVersion": 1.2,
        "position": [
          250,
          300
        ],
        "parameters": {
          "rule": {
            "interval": [
              {
                "field": "cronExpression",
                "expression": "0 9 * * *"
              }
            ]
          }
        }
      },
      {
        "id": "f4a2b3c4-0004-0004-0004-000000000002",
        "name": "Count Churn Risk",
        "type": "n8n-nodes-base.postgres",
        "typeVersion": 2.5,
        "position": [
          450,
          300
        ],
        "credentials": {
          "postgres": {
            "id": "1",
            "name": "PostgreSQL Otomaix"
          }
        },
        "parameters": {
          "operation": "executeQuery",
          "query": "SELECT COUNT(*)::int AS count FROM social.accounts a WHERE a.last_login_at < now() - interval '14 days' AND EXISTS (SELECT 1 FROM social.subscriptions s WHERE s.account_id = a.id AND s.status = 'active') AND NOT EXISTS (SELECT 1 FROM crm.account_tags t WHERE t.account_id = a.id AND t.tag = 'Churn Riski')",
          "options": {}
        }
      },
      {
        "id": "f4a2b3c4-0004-0004-0004-000000000003",
        "name": "Has Churn Risk?",
        "type": "n8n-nodes-base.if",
        "typeVersion": 2.2,
        "position": [
          650,
          300
        ],
        "parameters": {
          "conditions": {
            "options": {
              "caseSensitive": true,
              "leftValue": "",
              "typeValidation": "strict"
            },
            "conditions": [
              {
                "id": "d1",
                "leftValue": "={{ $json.count }}",
                "rightValue": 0,
                "operator": {
                  "type": "number",
                  "operation": "gt"
                }
              }
            ],
            "combinator": "and"
          }
        }
      },
      {
        "id": "f4a2b3c4-0004-0004-0004-000000000004",
        "name": "Get & Tag Churn Accounts",
        "type": "n8n-nodes-base.postgres",
        "typeVersion": 2.5,
        "position": [
          850,
          200
        ],
        "credentials": {
          "postgres": {
            "id": "1",
            "name": "PostgreSQL Otomaix"
          }
        },
        "parameters": {
          "operation": "executeQuery",
          "query": "WITH churn_accounts AS (SELECT a.id, a.email, a.name, a.last_login_at FROM social.accounts a WHERE a.last_login_at < now() - interval '14 days' AND EXISTS (SELECT 1 FROM social.subscriptions s WHERE s.account_id = a.id AND s.status = 'active') AND NOT EXISTS (SELECT 1 FROM crm.account_tags t WHERE t.account_id = a.id AND t.tag = 'Churn Riski')), inserted AS (INSERT INTO crm.account_tags (account_id, tag, added_by) SELECT id, 'Churn Riski', 'n8n-otomatik' FROM churn_accounts ON CONFLICT (account_id, tag) DO NOTHING) SELECT id, email, name, last_login_at FROM churn_accounts ORDER BY last_login_at ASC",
          "options": {}
        }
      },
      {
        "id": "f4a2b3c4-0004-0004-0004-000000000005",
        "name": "Aggregate Accounts",
        "type": "n8n-nodes-base.aggregate",
        "typeVersion": 1,
        "position": [
          1050,
          200
        ],
        "parameters": {
          "aggregate": "aggregateAllItemData",
          "destinationFieldName": "accounts",
          "options": {}
        }
      },
      {
        "id": "f4a2b3c4-0004-0004-0004-000000000006",
        "name": "Build Churn Message",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          1250,
          200
        ],
        "parameters": {
          "jsCode": "const accounts = $json.accounts;\nconst count = accounts.length;\n\nlet lines = accounts.slice(0, 10).map((a, i) => {\n  const days = Math.floor((Date.now() - new Date(a.last_login_at).getTime()) / 86400000);\n  return `${i+1}. ${a.name || a.email} — ${days} gündür giriş yok`;\n});\n\nif (count > 10) lines.push(`... ve ${count - 10} kişi daha`);\n\nconst text = `⚠️ <b>Churn Riski Taraması</b>\\n\\n` +\n  `${count} müşteri 14+ gündür giriş yapmadı ve <b>Churn Riski</b> etiketi eklendi.\\n\\n` +\n  lines.join('\\n') +\n  `\\n\\n🔗 <a href=\"https://crm.otomaix.com/musteriler?etiket=Churn+Riski\">CRM'de Görüntüle</a>`;\n\nreturn [{ json: { text } }];"
        }
      },
      {
        "id": "f4a2b3c4-0004-0004-0004-000000000007",
        "name": "Send Churn Alert",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.2,
        "position": [
          1450,
          200
        ],
        "parameters": {
          "method": "POST",
          "url": "https://api.telegram.org/bot8604791076:AAGxu_XtypVCcr7fX1HxDlbIceRXbP_8JPY/sendMessage",
          "sendBody": true,
          "specifyBody": "keypair",
          "bodyParameters": {
            "parameters": [
              {
                "name": "chat_id",
                "value": "1634464595"
              },
              {
                "name": "text",
                "value": "={{ $json.text }}"
              },
              {
                "name": "parse_mode",
                "value": "HTML"
              }
            ]
          },
          "options": {}
        }
      }
    ],
    "connections": {
      "Schedule Trigger": {
        "main": [
          [
            {
              "node": "Count Churn Risk",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Count Churn Risk": {
        "main": [
          [
            {
              "node": "Has Churn Risk?",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Has Churn Risk?": {
        "main": [
          [
            {
              "node": "Get & Tag Churn Accounts",
              "type": "main",
              "index": 0
            }
          ],
          []
        ]
      },
      "Get & Tag Churn Accounts": {
        "main": [
          [
            {
              "node": "Aggregate Accounts",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Aggregate Accounts": {
        "main": [
          [
            {
              "node": "Build Churn Message",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Build Churn Message": {
        "main": [
          [
            {
              "node": "Send Churn Alert",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    },
    "settings": {
      "executionOrder": "v1"
    }
  },
  {
    "name": "CRM-5: Deneme Süresi Bitiyor (Günlük)",
    "active": true,
    "nodes": [
      {
        "id": "f5a2b3c4-0005-0005-0005-000000000001",
        "name": "Schedule Trigger",
        "type": "n8n-nodes-base.scheduleTrigger",
        "typeVersion": 1.2,
        "position": [
          250,
          300
        ],
        "parameters": {
          "rule": {
            "interval": [
              {
                "field": "cronExpression",
