      {
        "id": "f5a2b3c4-0005-0005-0005-000000000002",
        "name": "Get Expiring Trials",
        "type": "n8n-nodes-base.postgres",
        "typeVersion": 2.5,
        "position": [
          450,
          300
        ],
        "credentials": {
          "postgres": {
            "id": "1",
            "name": "PostgreSQL Otomaix"
          }
        },
        "parameters": {
          "operation": "executeQuery",
          "query": "SELECT a.id, a.email, a.name, a.trial_ends_at FROM social.accounts a WHERE a.trial_ends_at IS NOT NULL AND a.trial_ends_at::date = (CURRENT_DATE + interval '2 days')::date AND NOT EXISTS (SELECT 1 FROM social.subscriptions s WHERE s.account_id = a.id AND s.status = 'active') ORDER BY a.trial_ends_at ASC",
          "options": {}
        }
      },
      {
        "id": "f5a2b3c4-0005-0005-0005-000000000003",
        "name": "Has Expiring Trials?",
        "type": "n8n-nodes-base.if",
        "typeVersion": 2.2,
        "position": [
          650,
          300
        ],
        "parameters": {
          "conditions": {
            "options": {
              "caseSensitive": true,
              "leftValue": "",
              "typeValidation": "strict"
            },
            "conditions": [
              {
                "id": "e1",
                "leftValue": "={{ $items().length }}",
                "rightValue": 0,
                "operator": {
                  "type": "number",
                  "operation": "gt"
                }
              }
            ],
            "combinator": "and"
          }
        }
      },
      {
        "id": "f5a2b3c4-0005-0005-0005-000000000004",
        "name": "Aggregate Trials",
        "type": "n8n-nodes-base.aggregate",
        "typeVersion": 1,
        "position": [
          850,
          200
        ],
        "parameters": {
          "aggregate": "aggregateAllItemData",
          "destinationFieldName": "trials",
          "options": {}
        }
      },
      {
        "id": "f5a2b3c4-0005-0005-0005-000000000005",
        "name": "Build Trial Message",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          1050,
          200
        ],
        "parameters": {
          "jsCode": "const trials = $json.trials;\nconst count = trials.length;\n\nlet lines = trials.map((t, i) => {\n  const endDate = new Date(t.trial_ends_at).toLocaleDateString('tr-TR');\n  return `${i+1}. ${t.name || t.email} — bitiş: ${endDate}`;\n});\n\nconst text = `📅 <b>Deneme Süresi Bitiyor</b>\\n\\n` +\n  `${count} hesabın deneme süresi <b>2 gün içinde</b> sona eriyor.\\n\\n` +\n  lines.join('\\n') +\n  `\\n\\n💡 Upgrade e-postası gönderilmesi önerilir.\\n🔗 <a href=\"https://crm.otomaix.com/musteriler\">CRM Müşteri Listesi</a>`;\n\nreturn [{ json: { text } }];"
        }
