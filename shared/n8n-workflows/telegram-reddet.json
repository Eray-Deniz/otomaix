      "webhookId": "7f55b3b2-8a38-449c-b52a-df0676805d6a"
    },
    {
      "id": "do-reject",
      "name": "Reddet",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        220,
        0
      ],
      "parameters": {
        "method": "PATCH",
