# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Docker Compose içindeki postgres servisi için şifre
POSTGRES_PASSWORD=guclu_bir_sifre_girin

# ─── Backend ─────────────────────────────────────────────────────────────────
# DATABASE_URL ve REDIS_URL docker-compose.yml içinde otomatik ayarlanır.
# Aşağıdaki değerleri kendi Supabase projenize göre doldurun.

SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGci...

# fal.ai — Görsel ve video üretimi
FAL_KEY=fal-xxxx

# Cloudflare R2 — Medya depolama
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=otomaix
R2_PUBLIC_URL=https://assets.example.com

# Upload-Post.com — Sosyal medya yayınlama
UPLOAD_POST_API_KEY=

# Anthropic Claude — İçerik üretimi ve AI analiz
ANTHROPIC_API_KEY=sk-ant-xxxx

# n8n → backend servis kimlik doğrulaması (rastgele bir değer girin)
INTERNAL_API_KEY=

# Uygulama URL'si (frontend)
APP_URL=http://localhost:3000

# ─── Opsiyonel Servisler ─────────────────────────────────────────────────────

# OpenAI — RAG chunk embedding (yoksa embedding devre dışı)
OPENAI_API_KEY=

# ElevenLabs — Kısa video TTS / seslendirme (yoksa TTS adımı atlanır)
ELEVENLABS_KEY=

# HeyGen — AI Avatar (yoksa stok avatar listesi kullanılır)
HEYGEN_API_KEY=

# Apify — Instagram rakip analizi (yoksa placeholder veri döner)
APIFY_API_KEY=

# Paddle — Ödeme sistemi (yoksa faturalandırma devre dışı)
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=

# Sentry — Hata izleme
SENTRY_DSN=
ENVIRONMENT=production

# PostHog — Kullanım analizi
POSTHOG_API_KEY=
POSTHOG_HOST=https://eu.posthog.com

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_ASSETS_URL=https://assets.example.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com
NEXT_PUBLIC_SENTRY_DSN=

# ─── n8n ─────────────────────────────────────────────────────────────────────
# n8n şifreleme anahtarı — rastgele 32+ karakter girin, bir kez ayarlayın, değiştirmeyin
N8N_ENCRYPTION_KEY=
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678
